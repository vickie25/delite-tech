# -----------------------------
# Server Configuration
# -----------------------------
# API port your backend runs on.
PORT=5000
# Use: development | production | test
NODE_ENV=development

# -----------------------------
# Database (PostgreSQL)
# -----------------------------
# Replace username/password/host/port/db-name with your real DB values.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/delight_tech?schema=public"

# -----------------------------
# JWT Auth
# -----------------------------
# Strong random secret for signing access tokens.
JWT_SECRET="dev-secret-change-me"
# Access token lifetime (examples: 15m, 1h, 7d)
JWT_EXPIRES_IN="15m"
# Strong random secret for refresh tokens (different from JWT_SECRET).
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
# Refresh token lifetime (examples: 7d, 30d)
JWT_REFRESH_EXPIRES_IN="30d"

# -----------------------------
# Admin Bootstrap (safe on every deploy)
# -----------------------------
# Initial/admin login email for dashboard access.
ADMIN_EMAIL="admin@yourdomain.com"
# Initial/admin login password (use a strong password in production).
ADMIN_PASSWORD="ChangeMeNow_123!"
# Optional display name for the admin account.
ADMIN_NAME="Main Admin"

# -----------------------------
# App URLs
# -----------------------------
# Public URL where this backend is reachable.
APP_BASE_URL="http://localhost:5000"
# Frontend URL used in reset-password email links.
FRONTEND_BASE_URL="http://localhost:5173"

# -----------------------------
# SMTP / Nodemailer
# -----------------------------
# SMTP provider host (examples: smtp.gmail.com, smtp.office365.com, mail.yourdomain.com)
SMTP_HOST="smtp.example.com"
# SMTP port: usually 587 (STARTTLS) or 465 (SSL/TLS)
SMTP_PORT=587
# true for SSL/TLS (usually port 465), false for STARTTLS (usually port 587)
SMTP_SECURE=false
# SMTP username (often your full email address)
SMTP_USER="your-smtp-user"
# SMTP password / app password from your provider
SMTP_PASS="your-smtp-password"
# Sender shown in outgoing emails
SMTP_FROM='"Delight Tech" <no-reply@yourdomain.com>'
